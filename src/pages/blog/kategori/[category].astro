---
import Base from '../../../layouts/Base.astro';
import { getCollection } from 'astro:content';

const categorySlug = (value) => value.toLocaleLowerCase('id-ID')
  .normalize('NFD').replace(/[\u0300-\u036f]/g, '')
  .replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, '');

export async function getStaticPaths() {
  const toSlug = (value) => value.toLocaleLowerCase('id-ID')
    .normalize('NFD').replace(/[\u0300-\u036f]/g, '')
    .replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, '');
  const posts = await getCollection('blog', ({ data }) => data.status === 'published');
  const categories = [...new Set(posts.flatMap((post) => post.data.categories || []))];
  return categories.map((category) => ({
    params: { category: toSlug(category) },
    props: {
      category,
      posts: posts.filter((post) => post.data.categories?.includes(category)
        || (category === 'Tembakau' && !post.data.categories?.length)),
    },
  }));
}

const { category, posts } = Astro.props;
posts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---
<Base title={`${category} | Blog Java Mbako`} description={`Artikel Java Mbako dalam kategori ${category}.`}>
  <nav class="breadcrumb" aria-label="Breadcrumb"><a href="/">Beranda</a><span aria-hidden="true">/</span><a href="/blog/">Blog</a><span aria-hidden="true">/</span><span aria-current="page">{category}</span></nav>
  <h1>Kategori: {category}</h1>
  <div class="post-list">
    {posts.map((post) => (
      <article class="post-item">
        <div>
          <time datetime={post.data.date.toISOString()}>{post.data.date.toLocaleDateString('id-ID')}</time>
          <h2><a href={`/blog/${post.data.slug || post.slug}/`}>{post.data.title}</a></h2>
          {post.data.description && <p>{post.data.description}</p>}
        </div>
      </article>
    ))}
  </div>
</Base>
