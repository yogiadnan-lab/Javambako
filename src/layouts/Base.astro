---
import '../styles/global.css';

const { title = 'Java Mbako', description = 'Khusus Jual Mbako Kualitas Tinggi', image = '' } = Astro.props;
const base = import.meta.env.BASE_URL;
const whatsappUrl = 'https://wa.me/6287776329910?text=Hi%20Java%20Mbako%20saya%20ingin%20bertanya';
const logo = `${base}logo.webp`;
---
<!doctype html>
<html lang="id">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="google-site-verification" content="Rtxs2RtrbkrCK3wvbQ8yPkCsaZAiK1CAwYItEkQ0zbQ" />
<meta name="google-site-verification" content="Rtxs2RtrbkrCK3wvbQ8yPkCsaZAiK1CAwYItEkQ0zbQ" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    {image && <meta property="og:image" content={image} />}
    <link rel="icon" type="image/webp" href={logo} />
    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-S85WD8K7QJ"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-S85WD8K7QJ');
    </script>
    <script is:inline>
      (function () {
        function isWhatsAppLink(url) {
          return url.includes('wa.me') ||
            url.includes('api.whatsapp.com') ||
            url.includes('whatsapp.com/send');
        }

        function buildWhatsAppUrl(originalUrl, message) {
          try {
            var url = new URL(originalUrl, window.location.origin);

            if (
              url.hostname.includes('wa.me') ||
              url.hostname.includes('whatsapp.com')
            ) {
              url.searchParams.set('text', message);
              return url.toString();
            }

            return originalUrl;
          } catch (e) {
            return originalUrl;
          }
        }

        function setupWhatsAppTracking() {
          var links = document.querySelectorAll('a[href]');
          var pageTitle = document.title || '';
          var pageUrl = window.location.href;
          var message =
            'Halo JavaTobacco, saya ingin bertanya tentang produk JavaTobacco. Saya datang dari halaman: ' +
            pageTitle +
            ' - ' +
            pageUrl;

          links.forEach(function (link) {
            var href = link.getAttribute('href') || '';

            if (!isWhatsAppLink(href)) return;

            var finalUrl = buildWhatsAppUrl(link.href, message);

            link.setAttribute('href', finalUrl);
            link.setAttribute('target', '_blank');
            link.setAttribute('rel', 'noopener noreferrer');
            link.setAttribute('data-track', 'whatsapp');

            link.addEventListener('click', function () {
              window.dataLayer = window.dataLayer || [];
              window.dataLayer.push({
                event: 'whatsapp_click',
                source_page_url: window.location.href,
                source_page_path: window.location.pathname,
                source_page_title: document.title,
                whatsapp_url: link.href,
                button_text: (link.innerText || link.getAttribute('aria-label') || 'WhatsApp CTA').trim()
              });
            });
          });
        }

        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', setupWhatsAppTracking);
        } else {
          setupWhatsAppTracking();
        }
      })();
    </script>
  </head>
  <body>
    <header class="site-header">
      <div class="container nav">
        <a class="brand" href={base} aria-label="Java Mbako beranda">
          <img class="brand-logo" src={logo} alt="Java Tobacco" />
          <span>Java Mbako</span>
        </a>
        <nav>
          <a href={`${base}#profile`}>Company Profile</a>
          <a href={`${base}#produk`}>Produk</a>
          <a href={`${base}#pemesanan`}>Langkah Pemesanan</a>
          <a href={`${base}blog/`}>Blog</a>
          <a href={`${base}daftar-mitra/`}>Daftar Kemitraan</a>
        </nav>
      </div>
    </header>
    <main class="container">
      <slot />
    </main>
    <footer class="site-footer">
      <div class="container footer-inner">
        <img src={logo} alt="Java Tobacco" loading="lazy" />
        <span>© {new Date().getFullYear()} Java Mbako</span>
      </div>
    </footer>
    <a
      class="floating-whatsapp"
      href={whatsappUrl}
      target="_blank"
      rel="noopener noreferrer"
      aria-label="Hubungi Java Mbako via WhatsApp"
      title="Hubungi Java Mbako via WhatsApp"
    >
      <svg viewBox="0 0 32 32" aria-hidden="true" focusable="false">
        <path d="M16 3C8.8 3 3 8.6 3 15.6c0 2.4.7 4.7 2 6.7L3.7 29l6.9-1.8c1.7.9 3.5 1.4 5.4 1.4 7.2 0 13-5.6 13-12.6S23.2 3 16 3Zm0 23.2c-1.7 0-3.3-.4-4.8-1.3l-.3-.2-4.1 1.1 1.1-4-.2-.4c-1.2-1.7-1.8-3.7-1.8-5.8 0-5.7 4.6-10.3 10.2-10.3 5.6 0 10.2 4.6 10.2 10.3S21.6 26.2 16 26.2Zm5.8-7.7c-.3-.2-1.9-.9-2.2-1-.3-.1-.5-.2-.7.2-.2.3-.8 1-.9 1.1-.2.2-.3.2-.6.1-.3-.2-1.3-.5-2.5-1.5-.9-.8-1.5-1.8-1.7-2.1-.2-.3 0-.5.1-.6.1-.1.3-.3.5-.5.1-.2.2-.3.3-.5.1-.2 0-.4 0-.5 0-.2-.7-1.8-1-2.4-.3-.6-.5-.5-.7-.5h-.6c-.2 0-.5.1-.8.4-.3.3-1 1-1 2.4s1 2.8 1.2 3c.2.2 2 3 4.8 4.2.7.3 1.2.5 1.6.6.7.2 1.3.2 1.8.1.6-.1 1.9-.8 2.1-1.5.3-.7.3-1.3.2-1.5 0-.1-.2-.2-.5-.4Z" />
      </svg>
    </a>
  </body>
</html>
